</div>

<scr` + `ipt>
(function(){
  var group = document.querySelectorAll('.${uid}_tab');
  var frame = document.getElementById('${uid}_frame');
  for (var i = 0; i < group.length; i++){
    group[i].addEventListener('click', function(){
      if(frame) frame.src = this.getAttribute('data-src') || '';
      for (var k = 0; k < group.length; k++){
        var active = (group[k] === this);
        group[k].style.background = active ? '#d4143a' : '#18161a';
        group[k].style.borderColor = active ? '#d4143a' : '#2a262c';
      }
    });
  }
})();
</scr` + `ipt>`;
}
document.getElementById('copyCode').addEventListener('click', ()=>{
  const text = document.getElementById('codeBox').textContent;
  navigator.clipboard?.writeText(text).then(()=>showToast('تم نسخ الكود إلى الحافظة.'))
    .catch(()=>showToast('تعذر نسخ الكود تلقائياً، انسخه يدوياً.'));
});

/* ================= TOAST ================= */
let toastTimer;
function showToast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>t.classList.remove('show'), 3200);
}

/* ================= INIT ================= */
(async function init(){
  await loadMovies();
  renderHome();
})();
</script>
