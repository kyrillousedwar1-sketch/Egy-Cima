<div dir="rtl" style="font-family:Tajawal,Cairo,Arial,sans-serif;background:#0a0a0d;color:#f3efee;padding:20px;border-radius:14px;max-width:900px;margin:0 auto;">

  <div style="display:flex;gap:20px;flex-wrap:wrap;margin-bottom:18px;">
    <img src="${m.poster}" alt="${m.title}" style="width:200px;border-radius:10px;border:1px solid #2a262c;flex:none;">
    <div style="flex:1;min-width:240px;">
      <h1 style="font-size:24px;font-weight:900;margin:0 0 10px;">${m.title} (${m.year||''})</h1>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;">
        <span style="background:#211d22;border:1px solid #2a262c;padding:4px 10px;border-radius:6px;font-size:12px;">${m.category}</span>
        <span style="background:#211d22;border:1px solid #2a262c;padding:4px 10px;border-radius:6px;font-size:12px;">${m.genre||''}</span>
        <span style="background:#211d22;border:1px solid #2a262c;padding:4px 10px;border-radius:6px;font-size:12px;">${m.duration||''}</span>
        <span style="background:#d4143a;padding:4px 10px;border-radius:6px;font-size:12px;font-weight:800;">${m.quality||''}</span>
      </div>
      <p style="color:#a79ca1;line-height:1.9;font-size:14.5px;">${(m.story||'لا يوجد وصف.').replace(/\n/g,' ')}</p>
    </div>
  </div>

  <h3 style="color:#ff2d4a;font-size:16px;margin:20px 0 10px;">🖥 سيرفرات المشاهدة</h3>
  <div style="margin-bottom:10px;">${tabsHtml || '<span style="color:#a79ca1;font-size:13px;">لا توجد سيرفرات مضافة.</span>'}</div>
  <div style="background:#000;border:1px solid #2a262c;border-radius:12px;overflow:hidden;aspect-ratio:16/9;margin-bottom:24px;">
    <iframe id="${uid}_frame" src="${serverUrls[0]||''}" allowfullscreen style="width:100%;height:100%;border:0;"></iframe>
  </div>

  <h3 style="color:#ff2d4a;font-size:16px;margin:20px 0 10px;">⬇ روابط التحميل المباشر</h3>
